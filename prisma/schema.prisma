  attended_by   BigInt?
  events        events    @relation(fields: [event_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([event_id, user_id], map: "uq_participation_event_user")
  @@index([event_id], map: "ix_participation_event_id")
  @@index([user_id], map: "ix_participation_user_id")
}

