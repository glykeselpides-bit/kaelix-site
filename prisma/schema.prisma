  completed_at           DateTime?        @db.Timestamp(6)
  expires_at             DateTime         @db.Timestamp(6)
  faction_quizzes        faction_quizzes? @relation(fields: [quiz_id], references: [id], onUpdate: NoAction)

  @@index([guild_id], map: "ix_onboarding_sessions_guild_id")
