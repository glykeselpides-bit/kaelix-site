  id           Int      @id @default(autoincrement())
  guild_id     BigInt
  user_id      BigInt
  activity_key String   @db.VarChar(80)
  enabled      Boolean
  created_at   DateTime @db.Timestamp(6)
  updated_at   DateTime @db.Timestamp(6)

  @@unique([guild_id, user_id, activity_key], map: "uq_user_activity_subscription")
  @@index([activity_key], map: "ix_user_activity_subscriptions_activity_key")
  @@index([guild_id], map: "ix_user_activity_subscriptions_guild_id")
  @@index([user_id], map: "ix_user_activity_subscriptions_user_id")
}

