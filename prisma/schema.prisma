generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

model active_item_effects {
  id                Int      @id @default(autoincrement())
  source_user_id    BigInt
  target_user_id    BigInt
  item_key          String   @db.VarChar(100)
  trivia_session_id Int
  applies_to_round  Int?
  applies_to_block  Int?
  is_consumed       Boolean
  created_at        DateTime @db.Timestamptz(6)
}

model activity_answers {
  id          Int      @id @default(autoincrement())
  session_id  Int
  user_id     BigInt
  question_id Int
  is_correct  Boolean
  answered_at DateTime @db.Timestamptz(6)
}

model activity_questions {
  id       Int    @id @default(autoincrement())
  question String @db.VarChar(500)
  answer   String @db.VarChar(200)
}

model activity_sessions {
  id                  Int       @id @default(autoincrement())
  is_active           Boolean
  started_at          DateTime  @db.Timestamptz(6)
  ended_at            DateTime? @db.Timestamptz(6)
  current_question_id Int?
  question_number     Int
  question_pool       Json      @db.Json
}

model audit_logs {
  id             Int      @id @default(autoincrement())
  guild_id       BigInt
  action_type    String   @db.VarChar(50)
  entity_type    String   @db.VarChar(50)
  entity_id      String?  @db.VarChar(50)
  actor_id       BigInt?
  target_user_id BigInt?
  details        String?  @db.VarChar(2000)
  created_at     DateTime @db.Timestamptz(6)

  @@index([action_type], map: "ix_audit_logs_action_type")
  @@index([actor_id], map: "ix_audit_logs_actor_id")
  @@index([guild_id, created_at], map: "ix_audit_logs_guild_created")
  @@index([guild_id], map: "ix_audit_logs_guild_id")
  @@index([target_user_id], map: "ix_audit_logs_target_user_id")
}

model caption_this_entries {
  id                Int      @id @default(autoincrement())
  session_id        Int
  guild_id          BigInt
  user_id           BigInt
  caption_text      String   @db.VarChar(500)
  voting_message_id BigInt?
  submitted_at      DateTime @db.Timestamptz(6)
}

model caption_this_sessions {
  id                          Int       @id @default(autoincrement())
  guild_id                    BigInt
  is_active                   Boolean
  phase                       String    @db.VarChar(20)
  image_url                   String    @db.VarChar(1000)
  reward_points               Int
  submission_ends_at          DateTime  @db.Timestamptz(6)
  voting_ends_at              DateTime? @db.Timestamptz(6)
  winner_user_id              BigInt?
  started_at                  DateTime  @db.Timestamptz(6)
  ended_at                    DateTime? @db.Timestamptz(6)
  channel_id                  BigInt?
  submission_duration_seconds Int
  voting_duration_seconds     Int
}

model caption_this_votes {
  id            Int      @id @default(autoincrement())
  session_id    Int
  guild_id      BigInt
  entry_id      Int
  voter_user_id BigInt
  created_at    DateTime @db.Timestamptz(6)
}

model cipher_sessions {
  id             Int       @id @default(autoincrement())
  guild_id       BigInt
  is_active      Boolean
  word_id        Int
  scrambled_word String    @db.VarChar(100)
  started_at     DateTime  @db.Timestamptz(6)
  ended_at       DateTime? @db.Timestamptz(6)
  winner_user_id BigInt?
}

model cipher_words {
  id            Int     @id @default(autoincrement())
  word          String  @db.VarChar(100)
  hint          String? @db.VarChar(300)
  difficulty    String? @db.VarChar(50)
  reward_points Int
}

model emoji_race_participants {
  id            Int      @id @default(autoincrement())
  session_id    Int
  guild_id      BigInt
  user_id       BigInt
  is_eliminated Boolean
  joined_at     DateTime @db.Timestamptz(6)
}

model emoji_race_prompts {
  id             Int     @id @default(autoincrement())
  prompt_text    String  @db.VarChar(300)
  option_1       String  @db.VarChar(20)
  option_2       String  @db.VarChar(20)
  option_3       String  @db.VarChar(20)
  option_4       String  @db.VarChar(20)
  correct_option Int
  difficulty     String? @db.VarChar(50)
  reward_points  Int
}

model emoji_race_responses {
  id           Int      @id @default(autoincrement())
  session_id   Int
  guild_id     BigInt
  round_number Int
  prompt_id    Int
  user_id      BigInt
  emoji        String   @db.VarChar(20)
  is_correct   Boolean
  answered_at  DateTime @db.Timestamptz(6)
}

model emoji_race_sessions {
  id                 Int       @id @default(autoincrement())
  guild_id           BigInt
  is_active          Boolean
  has_started        Boolean
  total_rounds       Int
  current_round      Int
  current_prompt_id  Int?
  current_message_id BigInt?
  current_channel_id BigInt?
  prompt_pool        Json?     @db.Json
  started_at         DateTime  @db.Timestamptz(6)
  ended_at           DateTime? @db.Timestamptz(6)
}

model event_reminder_logs {
  id             Int      @id @default(autoincrement())
  guild_id       BigInt
  event_id       Int
  user_id        BigInt
  offset_minutes Int
  created_at     DateTime @db.Timestamptz(6)

  @@unique([guild_id, event_id, user_id, offset_minutes], map: "uq_event_reminder_log_guild_event_user_offset")
  @@index([event_id], map: "ix_event_reminder_logs_event_id")
  @@index([event_id, offset_minutes], map: "ix_event_reminder_logs_event_offset")
  @@index([guild_id], map: "ix_event_reminder_logs_guild_id")
  @@index([guild_id, user_id], map: "ix_event_reminder_logs_guild_user")
  @@index([user_id], map: "ix_event_reminder_logs_user_id")
}

model event_rewards {
  id                   Int      @id @default(autoincrement())
  event_id             Int
  user_id              BigInt
  guild_id             BigInt
  points_awarded       Int
  awarded_by           BigInt?
  point_transaction_id Int?
  created_at           DateTime @db.Timestamptz(6)
  events               events   @relation(fields: [event_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([event_id, user_id], map: "uq_event_rewards_event_user")
  @@index([event_id], map: "ix_event_rewards_event_id")
  @@index([user_id], map: "ix_event_rewards_user_id")
}

model events {
  id                      Int             @id @default(autoincrement())
  event_code              String          @unique(map: "uq_events_event_code") @db.VarChar(4)
  guild_id                BigInt
  channel_id              BigInt
  name                    String          @db.VarChar(100)
  starts_at               DateTime        @db.Timestamptz(6)
  source_timezone         String          @db.VarChar(64)
  created_by              BigInt
  reward_points           Int
  recurrence              String          @db.VarChar(16)
  series_id               String?         @db.VarChar(36)
  is_series_template      Boolean
  reminder_offsets        String          @db.VarChar(200)
  sent_reminders          String          @db.VarChar(200)
  notification_role_ids   String          @db.VarChar(500)
  status                  String          @db.VarChar(20)
  announcement_channel_id BigInt?
  announcement_message_id BigInt?
  created_at              DateTime        @db.Timestamptz(6)
  event_rewards           event_rewards[]
  participation           participation[]

  @@index([event_code], map: "ix_events_event_code")
  @@index([guild_id], map: "ix_events_guild_id")
  @@index([series_id], map: "ix_events_series_id")
}

model faction_answers {
  id                Int               @id @default(autoincrement())
  question_id       Int
  faction_id        Int
  answer_text       String            @db.VarChar(300)
  answer_order      Int
  points            Int
  factions          factions          @relation(fields: [faction_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  faction_questions faction_questions @relation(fields: [question_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([faction_id], map: "ix_faction_answers_faction_id")
  @@index([question_id], map: "ix_faction_answers_question_id")
}

model faction_questions {
  id              Int               @id @default(autoincrement())
  quiz_id         Int
  question_text   String            @db.VarChar(500)
  question_order  Int
  is_active       Boolean
  faction_answers faction_answers[]
  faction_quizzes faction_quizzes   @relation(fields: [quiz_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([quiz_id], map: "ix_faction_questions_quiz_id")
}

model faction_quizzes {
  id                  Int                   @id @default(autoincrement())
  guild_id            BigInt
  name                String                @db.VarChar(100)
  description         String?               @db.VarChar(500)
  is_active           Boolean
  allow_retake        Boolean
  created_at          DateTime              @db.Timestamp(6)
  updated_at          DateTime              @db.Timestamp(6)
  faction_questions   faction_questions[]
  onboarding_sessions onboarding_sessions[]
  user_factions       user_factions[]

  @@index([guild_id], map: "ix_faction_quizzes_guild_id")
}

model factions {
  id              Int               @id @default(autoincrement())
  guild_id        BigInt
  key             String            @db.VarChar(50)
  name            String            @db.VarChar(100)
  description     String?           @db.VarChar(500)
  role_id         BigInt?
  emoji           String?           @db.VarChar(50)
  color           String?           @db.VarChar(20)
  is_active       Boolean
  created_at      DateTime          @db.Timestamp(6)
  updated_at      DateTime          @db.Timestamp(6)
  faction_answers faction_answers[]
  user_factions   user_factions[]

  @@index([guild_id], map: "ix_factions_guild_id")
}

model gif_battle_entries {
  id                    Int      @id @default(autoincrement())
  session_id            Int
  guild_id              BigInt
  user_id               BigInt
  gif_url               String   @db.VarChar(1000)
  caption               String?  @db.VarChar(300)
  submission_message_id BigInt?
  voting_message_id     BigInt?
  submitted_at          DateTime @db.Timestamptz(6)
}

model gif_battle_sessions {
  id                          Int       @id @default(autoincrement())
  guild_id                    BigInt
  channel_id                  BigInt?
  is_active                   Boolean
  phase                       String    @db.VarChar(20)
  prompt_text                 String    @db.VarChar(300)
  reward_points               Int
  submission_duration_seconds Int
  voting_duration_seconds     Int
  submission_ends_at          DateTime  @db.Timestamptz(6)
  voting_ends_at              DateTime? @db.Timestamptz(6)
  winner_user_id              BigInt?
  started_at                  DateTime  @db.Timestamptz(6)
  ended_at                    DateTime? @db.Timestamptz(6)
}

model gif_battle_votes {
  id            Int      @id @default(autoincrement())
  session_id    Int
  guild_id      BigInt
  entry_id      Int
  voter_user_id BigInt
  created_at    DateTime @db.Timestamptz(6)
}

model guild_config {
  guild_id                      BigInt    @id @default(autoincrement())
  points_per_message            Int
  points_per_reaction           Int
  default_event_points          Int
  voice_points_per_minute       Int
  message_cooldown_seconds      Int
  reaction_cooldown_seconds     Int
  voice_reward_interval_seconds Int
  enable_message_points         Boolean
  enable_reaction_points        Boolean
  enable_event_points           Boolean
  enable_voice_points           Boolean
  enable_achievements           Boolean
  enable_activities             Boolean
  excluded_channel_ids          Json      @db.Json
  excluded_role_ids             Json      @db.Json
  bonus_channel_ids             Json      @db.Json
  send_dm_notifications         Boolean
  event_reminder_channel_id     BigInt?
  admin_log_channel_id          BigInt?
  onboarding_enabled            Boolean
  active_quiz_id                BigInt?
  allow_retake                  Boolean
  result_visibility             String    @db.VarChar(20)
  welcome_channel_id            BigInt?
  weekly_summary_enabled        Boolean
  weekly_summary_channel_id     BigInt?
  weekly_summary_day            Int
  weekly_summary_hour           Int
  weekly_summary_minute         Int
  weekly_summary_last_sent_at   DateTime? @db.Timestamptz(6)
  extra_settings                Json      @db.Json
}

model guild_feature_overrides {
  id                 Int       @id @default(autoincrement())
  guild_id           BigInt
  key                String    @db.VarChar(128)
  bool_value         Boolean?
  int_value          Int?
  source             String    @db.VarChar(64)
  reason             String?
  expires_at         DateTime? @db.Timestamptz(6)
  created_at         DateTime  @default(now()) @db.Timestamptz(6)
  updated_at         DateTime  @default(now()) @db.Timestamptz(6)
  string_value       String?   @db.VarChar(128)
  created_by_user_id BigInt?

  @@unique([guild_id, key, source, expires_at], map: "uq_guild_feature_override_scope")
  @@index([guild_id, key, expires_at, updated_at], map: "ix_guild_feature_override_lookup")
  @@index([guild_id], map: "ix_guild_feature_overrides_guild_id")
  @@index([key], map: "ix_guild_feature_overrides_key")
}

model guild_subscriptions {
  id                     Int       @id @default(autoincrement())
  guild_id               BigInt    @unique(map: "ix_guild_subscriptions_guild_id")
  plan                   String    @db.VarChar(32)
  status                 String    @db.VarChar(32)
  stripe_customer_id     String?   @db.VarChar(255)
  stripe_subscription_id String?   @db.VarChar(255)
  current_period_end     DateTime? @db.Timestamptz(6)
  trial_used             Boolean
  trial_ends_at          DateTime? @db.Timestamptz(6)
  cancel_at_period_end   Boolean
  created_at             DateTime  @default(now()) @db.Timestamptz(6)
  updated_at             DateTime  @default(now()) @db.Timestamptz(6)

  @@index([plan, status], map: "ix_guild_subscription_plan_status")
  @@index([stripe_subscription_id], map: "ix_guild_subscriptions_stripe_subscription_id")
}

