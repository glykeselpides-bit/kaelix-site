  quiz_id           Int?
  assignment_source String           @db.VarChar(50)
  assigned_by       BigInt?
  assigned_at       DateTime         @db.Timestamp(6)
  factions          factions         @relation(fields: [faction_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  faction_quizzes   faction_quizzes? @relation(fields: [quiz_id], references: [id], onUpdate: NoAction)

  @@index([faction_id], map: "ix_user_factions_faction_id")
  @@index([guild_id], map: "ix_user_factions_guild_id")
  @@index([user_id], map: "ix_user_factions_user_id")
}

